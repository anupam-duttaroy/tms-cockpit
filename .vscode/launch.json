{
    "version": "0.2.0",
    "configurations": [
        {
            "type"   : "node",
            "request": "attach",
            "name"   : "Attach to BTP",
            "port"   : 9229,
            "restart": true,
            "localRoot" : "${workspaceFolder}",
            "remoteRoot": "/home/vcap/app",
            "sourceMapPathOverrides": {
                "/home/vcap/app/*": "${workspaceFolder}/*"
            }
        }
    ]
}