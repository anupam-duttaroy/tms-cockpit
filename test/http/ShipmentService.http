@username=user01
@password=

### updateShipmentStatus
# @name updateShipmentStatus_POST
POST {{server}}/odata/v4/shipment/updateShipmentStatus
Content-Type: application/json
Authorization: Basic {{username}}:{{password}}

{
  "delivery": "8001004",
  "status": "complete"
}


### createBilling
# @name createBilling_POST
POST {{server}}/odata/v4/shipment/createBilling
Content-Type: application/json
Authorization: Basic {{username}}:{{password}}

{
  "shipmentNumber": "8001004"
