{
  "name": "tms-cockpit",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "^3.12.0",
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.6.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "passport": "^0.7.0",
    "sap-cf-mailer": "^0.0.5"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "node --test",
    "debug": "cds watch",
    "watch-tms-cockpit-fe": "cds watch --open tmscockpitfe/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy tms-cockpit --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-tms-cockpit-alp": "cds watch --open tmscockpitalp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "db": {
          "kind": "sqlite",
          "users": {
            "User01": {}
          },
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "auth": "mocked"
      },
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": "xsuaa"
      },
      "destinations": true,
      "malware-scanner": true,
      "connectivity": true
    },
    "server": {
      "body_parser": {
        "limit": "10mb"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/tms-cockpit-fe",
    "app/tms-cockpit-alp"
  ]
}
