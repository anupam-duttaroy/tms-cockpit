{
  "name": "tms-cockpit",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "^3.12.0",
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.6.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "dotenv": "^17.4.2",
    "passport": "^0.7.0",
    "sap-cf-mailer": "^0.0.5"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "node --test",
    "debug": "cds watch"
  },
  "private": true,
  "cds": {
    "requires": {
      "[development]": {
        "db": {
          "kind": "sqlite",
          "users": {
            "User01": {}
          },
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "auth": "mocked"
      },
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": "xsuaa"
      },
      "destinations": true,
      "malware-scanner": true,
      "connectivity": true
    },
    "server": {
      "body_parser": {
        "limit": "10mb"
      }
    }
  }
}
